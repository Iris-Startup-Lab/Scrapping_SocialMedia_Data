# LLMs — APIs oficiales de cada proveedor
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # https://platform.claude.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here      # https://platform.deepseek.com

# Search
SERPAPI_API_KEY=your_serpapi_key_here

# APIs Oficiales
YOUTUBE_API_KEY=your_youtube_api_key
MAPS_API_KEY=your_google_maps_key
MAPBOX_TOKEN=your_mapbox_access_token_here_optional
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=chismesito_gpt_v2/1.0

# APIFY (plan $29/mes)
APIFY_API_KEY=your_apify_api_key

# Supabase (PostgreSQL + pgvector)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key

# App
APP_ENV=development
LOG_LEVEL=INFO

# Auth — Whitelist de emails autorizados para ChismesitoGPT
# Formato: email1@dominio.com,email2@dominio.com
# Si está vacío: cualquier usuario de Supabase Auth puede acceder (NO recomendado)
ALLOWED_EMAILS=tu@email.com,colega@empresa.com
